# --- Banco de dados ---
DATABASE_URL="postgresql://user:password@localhost:5432/expost_ai"

# --- Autenticação (Auth.js) ---
NEXTAUTH_URL="https://app.expost.ai"
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"

# --- Armazenamento (AWS S3 ou equivalente) ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="expost-ai-media"

# --- OpenAI (título, descrição, hashtags) ---
OPENAI_API_KEY=""

# --- E-mail transacional (ativação de licença, notificações) ---
RESEND_API_KEY=""
EMAIL_FROM="ExPost AI <contas@expost.ai>"

# --- Cakto (assinatura recorrente) ---
CAKTO_API_KEY=""
CAKTO_WEBHOOK_SECRET=""          # usado para validar a assinatura HMAC do webhook
CAKTO_PRODUCT_ID=""              # id do produto/assinatura de R$18,99/mês

# --- Criptografia de tokens OAuth armazenados no banco ---
TOKEN_ENCRYPTION_KEY="gere-com-openssl-rand-base64-32"

# --- OAuth oficial das redes sociais ---
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""

TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

META_APP_ID=""                   # usado para Instagram + Facebook (Graph API)
META_APP_SECRET=""

X_CLIENT_ID=""
X_CLIENT_SECRET=""

LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

PINTEREST_APP_ID=""
PINTEREST_APP_SECRET=""
